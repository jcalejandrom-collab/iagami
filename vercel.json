{
  "version": 2,
  "builds": [
    {
      "src": "sistema-control/backend/src/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "sistema-control/backend/src/app.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
