PORT=4000

# Cadena de conexión a PostgreSQL.
# En Docker Compose, reemplaza 'localhost' por el nombre del servicio (ej: 'db').
# El usuario debe tener solo los permisos mínimos necesarios (ver schema.sql).
DATABASE_URL=postgresql://app_writer:CAMBIA_ESTA_CONTRASENA@localhost:5432/iagami_forms

# Secreto JWT — genera uno real con: openssl rand -base64 64
# NUNCA uses el valor de ejemplo en producción.
JWT_SECRET=REEMPLAZA_CON_SALIDA_DE__openssl_rand_-base64_64
JWT_EXPIRES_IN=8h

# Verificación TLS al conectar con PostgreSQL.
# Mantener en true en producción. Solo false en desarrollo local con
# certificados autofirmados conocidos — desactivarlo en producción permite MITM.
DB_SSL_REJECT_UNAUTHORIZED=true

# Entorno de ejecución (development | production)
NODE_ENV=production

# URL del frontend autorizado (bloquea CORS de otros orígenes).
FRONTEND_URL=https://tu-dominio-oficial.gob.ve

# Directorio de uploads (relativo a la raíz del backend)
UPLOAD_DIR=src/uploads

# Tamaño máximo de archivo en MB (no aumentar por encima de 10)
MAX_FILE_SIZE_MB=5
