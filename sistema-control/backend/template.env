# ─── Base de datos ────────────────────────────────────────────────────────────
# PC fija local:
DATABASE_URL=postgresql://postgres:tu_password@localhost:5432/iagami_forms
# Neon (producción Vercel): copiar DATABASE_URL desde el panel de Neon

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro

# ─── Entorno ──────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Frontend ─────────────────────────────────────────────────────────────────
# PC fija local:
FRONTEND_URL=http://localhost:3000
# Producción:
# FRONTEND_URL=https://iagami.vercel.app

# ─── PocketBase ───────────────────────────────────────────────────────────────
# URL de PocketBase (usado si el backend necesita consultarla)
PB_URL=http://127.0.0.1:8090

# ─── Uploads ──────────────────────────────────────────────────────────────────
# Tamaño máximo de archivo en MB (default: 5)
MAX_FILE_SIZE_MB=5
